SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Gemini (choose one auth method) ──────────────────────────────────────────

# Option A: Google AI Studio API key (easiest — no GCP setup required)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI via Application Default Credentials
# Run: gcloud auth application-default login
# If GEMINI_API_KEY is set, these are ignored.
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Last.fm (optional) ───────────────────────────────────────────────────────
# Enriches commentary with play counts, loved tracks, and listening history.
# Register at https://www.last.fm/api/account/create
# LASTFM_API_KEY=your_lastfm_api_key_here
# LASTFM_API_SECRET=your_lastfm_shared_secret_here

# ── Tuning ───────────────────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-pro
MAX_TRACKS=30
# PORT=8765
